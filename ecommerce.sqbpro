e="35"/><column index="2" value="90"/><column index="3" value="68"/><column index="4" value="56"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="produits" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="135"/><column index="3" value="55"/><column index="4" value="143"/><column index="5" value="43"/><column index="6" value="81"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="utilisateurs" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="35"/><column index="3" value="39"/><column index="4" value="92"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- TABLE CATEGORIES
CREATE TABLE categories (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    nom TEXT NOT NULL
);

-- TABLE PRODUITS
CREATE TABLE produits (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    nom TEXT NOT NULL,
    prix REAL NOT NULL,
    description TEXT,
    image TEXT,
    categorie_id INTEGER,
    FOREIGN KEY (categorie_id) REFERENCES categories(id)
);

-- TABLE UTILISATEURS
CREATE TABLE utilisateurs (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    nom TEXT,
    email TEXT UNIQUE,
    mot_de_passe TEXT
);

-- TABLE COMMANDES
CREATE TABLE commandes (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    utilisateur_id INTEGER,
    date_commande TEXT,
    FOREIGN KEY (utilisateur_id) REFERENCES utilisateurs(id)
);

-- TABLE DETAILS_COMMANDE
CREATE TABLE details_commande (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    commande_id INTEGER,
    produit_id INTEGER,
    quantite INTEGER,
    FOREIGN KEY (commande_id) REFERENCES commandes(id),
    FOREIGN KEY (produit_id) REFERENCES produits(id)
);

INSERT INTO categories (nom) VALUES ('Montres');
INSERT INTO categories (nom) VALUES ('Sacs femmes');
INSERT INTO categories (nom) VALUES ('Vêtements');

-- Montres
INSERT INTO produits (nom, prix, description, categorie_id) VALUES ('Montre Luxe', 1200, 'Belle montre', 1);
